# Same Neon database as the main app — the worker upserts into the shared
# products table. NOTE: the pg driver does not support channel binding, so the
# connection string must NOT include channel_binding=require.
DATABASE_URL=postgresql://neondb_owner:npg_uhN87VRsqvdX@ep-proud-haze-abx1wayi-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Informational fallback FX rate. The worker fetches the live GBP→USD rate from
# Frankfurter (cached 6h) and falls back to 1.33 if that fetch fails.
GBP_TO_USD_RATE=1.33

# Cron schedule (defaults to every 6 hours)
CRON_SCHEDULE=0 */6 * * *
